{
  "opencollection": "1.0.0",
  "info": {
    "name": "Taddy Podcast API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "X-API-KEY",
      "value": "{{X-API-KEY}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "GraphQL",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Execute GraphQL Query",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.taddy.org/",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Execute a GraphQL query against the Taddy API. Supports queries for podcast series, episodes, search, top charts, transcripts, and webhooks."
        }
      ]
    }
  ],
  "bundled": true
}